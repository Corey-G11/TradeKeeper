# Copy to .env (local) or set these as environment variables on your host.
# NEVER commit real secrets. NEVER paste them into chat.

TRADOVATE_ENV=demo            # demo (sim) or live
TRADOVATE_CID=                # your Tradovate API key id  (request via Tradovate)
TRADOVATE_SEC=                # your Tradovate API secret
TRADOVATE_USERNAME=           # your Tradovate username
TRADOVATE_PASSWORD=           # your Tradovate password
TRADOVATE_APP_NAME=TradeKeeper

PORT=8080
ALLOW_ORIGIN=https://corey-g11.github.io   # lock CORS to your app in prod
